    "lines": [
      {
        "t": 12.09,
        "end": 20.86,
        "chars": [
          1
        ],
        "who": "Dexter",
        "text": "Okay Deb... Don't be dead.",
        "de": "Okay Deb... sei bitte nicht tot.",
        "orig": "scenes/dexter/lines/01.mp3"
      },
      {
        "t": 20.86,
        "end": 23.77,
        "chars": [
          1
        ],
        "who": "Dexter",
        "text": "Shit (under breath)",
        "de": "Scheiße (leise vor sich hin)",
        "orig": "scenes/dexter/lines/02.mp3"
      },
      {
        "t": 23.77,
        "end": 27.45,
        "chars": [
          2
        ],
        "who": "Doakes",
        "text": "Surpise Mothafucka'",
        "de": "Überraschung, Kumpel!",
        "orig": "scenes/dexter/lines/03.mp3"
      },
      {
        "t": 27.45,
        "end": 28.74,
        "chars": [
          1
        ],
        "who": "Dexter",
        "text": "You following me now?",
        "de": "Verfolgst du mich jetzt?",
        "orig": "scenes/dexter/lines/04.mp3"
      },
      {
        "t": 28.74,
        "end": 30.57,
        "chars": [
          2
        ],
        "who": "Doakes",
        "text": "Better have a hell of a reason for being here.",
        "de": "Du hast hoffentlich einen verdammt guten Grund, hier zu sein.",
        "orig": "scenes/dexter/lines/05.mp3"
      },
      {
        "t": 30.57,
        "end": 31.74,
        "chars": [
          1
        ],
        "who": "Dexter",
        "text": "Lookin for my sister.",
        "de": "Ich such meine Schwester.",
        "orig": "scenes/dexter/lines/06.mp3"
      },
      {
        "t": 31.74,
        "end": 33.34,
        "chars": [
          2
        ],
        "who": "Doakes",
        "text": "In a cargo box?",
        "de": "In einem Frachtcontainer?",
        "orig": "scenes/dexter/lines/07.mp3"
      },
      {
        "t": 33.34,
        "end": 34.74,
        "chars": [
          1
        ],
        "who": "Dexter",
        "text": "Yeah i'm kinda working on a theory.",
        "de": "Ja, ich arbeite da so an einer Theorie.",
        "orig": "scenes/dexter/lines/08.mp3"
      },
      {
        "t": 34.74,
        "end": 38.42,
        "chars": [
          2
        ],
        "who": "Doakes",
        "text": "You forget you work for the fucking cops? We love theories c'mon spin me a story asshole.",
        "de": "Hast du vergessen, dass du für die verdammten Cops arbeitest? Wir lieben Theorien — na los, erzähl mir ein Märchen, Arschloch.",
        "orig": "scenes/dexter/lines/09.mp3"
      },
      {
        "t": 38.42,
        "end": 40.13,
        "chars": [
          1
        ],
        "who": "Dexter",
        "text": "What I do on my time is my business Sgt.",
        "de": "Was ich in meiner Freizeit mache, ist meine Sache, Sergeant.",
        "orig": "scenes/dexter/lines/10.mp3"
      },
      {
        "t": 40.13,
        "end": 46.1,
        "chars": [
          2
        ],
        "who": "Doakes",
        "text": "Yeah, me too. And I'm on my time now. There's no liutenant here to save your ass so don't fuck with me Morgan.",
        "de": "Ja, ich auch. Und ich hab gerade Feierabend. Hier ist kein Lieutenant, der deinen Arsch rettet — also leg dich nicht mit mir an, Morgan.",
        "orig": "scenes/dexter/lines/11.mp3"
      },
      {
        "t": 46.1,
        "end": 48.19,
        "chars": [
          1
        ],
        "who": "Dexter",
        "text": "Alright, you got me.",
        "de": "Okay, du hast mich erwischt.",
        "orig": "scenes/dexter/lines/12.mp3"
      },
      {
        "t": 48.19,
        "end": 52.04,
        "chars": [
          1
        ],
        "who": "Dexter",
        "text": "Ordered some furniture from Thailand I was waiting for it to be deli-",
        "de": "Hab Möbel aus Thailand bestellt, ich hab auf die Lieferung gewar—",
        "orig": "scenes/dexter/lines/13.mp3"
      },
      {
        "t": 52.04,
        "end": 60.46,
        "chars": [
          1,
          2
        ],
        "who": "Both",
        "text": "*angry fighting noises*",
        "de": "*wütende Kampfgeräusche*",
        "orig": "scenes/dexter/lines/14.mp3"
      },
      {
        "t": 60.46,
        "end": 61.95,
        "chars": [
          2
        ],
        "who": "Doakes",
        "text": "Lab geek my ass.",
        "de": "Labor-Nerd, von wegen.",
        "orig": "scenes/dexter/lines/15.mp3"
      },
      {
        "t": 61.95,
        "end": 63.37,
        "chars": [
          1,
          2
        ],
        "who": "Both",
        "text": "*weird snarling*",
        "de": "*komisches Knurren*",
        "orig": "scenes/dexter/lines/16.mp3"
      },
      {
        "t": 63.37,
        "end": 67.55,
        "chars": [
          3
        ],
        "who": "Random dude",
        "text": "Hey, the hell's going on over here?! Security I need to get somebody down here right now.",
        "de": "Hey, was zur Hölle ist hier los?! Security, ich brauch sofort jemanden hier unten!",
        "orig": "scenes/dexter/lines/17.mp3"
      },
      {
        "t": 67.55,
        "end": 68.8,
        "chars": [
          2
        ],
        "who": "Doakes",
        "text": "Miami Metro PD.",
        "de": "Miami Metro PD.",
        "orig": "scenes/dexter/lines/18.mp3"
      },
      {
        "t": 68.8,
        "end": 70.39,
        "chars": [
          3
        ],
        "who": "Random dude",
        "text": "Yeah well is this guy under arrest?",
        "de": "Ja und, ist der Typ jetzt verhaftet?",
        "orig": "scenes/dexter/lines/19.mp3"
      },
      {
        "t": 70.39,
        "end": 71.68,
        "chars": [
          1
        ],
        "who": "Dexter",
        "text": "That's a good question.",
        "de": "Gute Frage.",
        "orig": "scenes/dexter/lines/20.mp3"
      },
      {
        "t": 71.68,
        "end": 81.0,
        "chars": [
          2
        ],
        "who": "Doakes",
        "text": "You're connected to this. I don't know how but i'm gonna find out and some of what I find is gonna stick to yo ass.",
        "de": "Du steckst da mit drin. Ich weiß noch nicht wie, aber ich find's raus — und irgendwas davon bleibt an deinem Arsch kleben.",
        "orig": "scenes/dexter/lines/21.mp3"
      }
    ]
  },
