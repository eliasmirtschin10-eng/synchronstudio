          1
        ],
        "who": "Will Smith",
        "text": "Can a robot write a symphony?",
        "de": "Kann ein Roboter eine Symphonie schreiben?",
        "orig": "scenes/irobot/lines/01.mp3"
      },
      {
        "t": 4.45,
        "end": 9.0,
        "chars": [
          1
        ],
        "who": "Will Smith",
